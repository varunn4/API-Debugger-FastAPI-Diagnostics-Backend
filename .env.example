# Copy this file to .env to override defaults.

# Logging
LOG_LEVEL=INFO

# SQLite database location
DEBUGGER_DB_PATH=debugger.db

# In-memory cache (per-process)
CACHE_MAX_SIZE=100
CACHE_TTL_MINUTES=30

# Deduplicate DB inserts within this time window (minutes)
DB_DEDUP_MINUTES=5

# slowapi rate limit for the debug endpoint(s)
DEBUG_RATE_LIMIT=10/minute

